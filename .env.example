# ============================================
# BiblioTech — Variáveis de Ambiente
# ============================================
# Copie para .env.local e preencha com seus valores reais.

# Banco de dados (Neon ou Supabase — PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/bibliotech?sslmode=require"

# NextAuth — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Admin (usado no seed inicial)
ADMIN_EMAIL="admin@bibliotech.com"
ADMIN_PASSWORD=""

# Cloudinary (tier free — 25GB)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
